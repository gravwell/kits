{
	"UUID": "c2a9f350-70c5-40d5-b6f2-5b887b87c60a",
	"Name": "Template - Auth0 - User - Authentication - Leaked Password Login Attempts [table]",
	"Description": "Displays a table of events performed indicating a high number of login attempts using a leaked password.\n\nReference(s): \n- https://auth0.com/docs/secure/security-guidance/incident-response-using-logs#indicators-of-an-attack",
	"Data": {
		"variables": [
			{
				"name": "%%src_ip%%",
				"label": "Source IP Address",
				"description": "This is the IP Address that you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			},
			{
				"name": "%%user_id%%",
				"label": "User ID",
				"description": "This is the User ID (user_id) that you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			},
			{
				"name": "%%user_name%%",
				"label": "User",
				"description": "This is the User (user_name) who you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"auth0"
	]
}