{
	"UUID": "6937f792-0703-4f7e-9d18-8eaf777b3b89",
	"Name": "Template - Auth0 - User - Authentication - Failed Login [table]",
	"Description": "Displays a table of failed login attempts with invalid usernames or non-existent users.\n\nReference(s):\n- https://auth0.com/docs/secure/security-guidance/incident-response-using-logs#indicators-of-an-attack",
	"Data": {
		"variables": [
			{
				"name": "%%src_ip%%",
				"label": "Source IP Address",
				"description": "This is the IP Address that you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			},
			{
				"name": "%%user_id%%",
				"label": "User ID",
				"description": "This is the User ID (user_id) that you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			},
			{
				"name": "%%user_name%%",
				"label": "User",
				"description": "This is the User (user_name) who you are investigating.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"auth0"
	]
}