// AUTH0_FILTER_CATEGORY
| alias eventType eventCode
| lookup -r auth0_eventTypes eventCode eventCode (category subcategory eventType)
| eval 
    if (has(eventCode) && (eventCode != "" || eventCode != "null" || eventCode != "nil") && in(eventCode, "actions_execution_failed","api_limit","ciba_exchange_failed","ciba_start_failed","f","fc","fce","fco","fcoa","fcp","fcph","fcpn","fcpr","fcpro","fcu","fd","fdeac","fdeaz","fdecc","fdu","feacft","feccft","fecte","fede","federated_logout_failed","fens","feoobft","feotpft","fepft","fepotpft","fercft","ferrt","fertft","fi","flo","flows_execution_failed","fn","forms_submission_failed","fp","fpar","fpurh","fs","fsa","fu","fui","fv","fvr","gd_auth_fail_email_verification","gd_auth_failed","gd_auth_rejected","gd_recovery_failed","gd_send_email_verification_failure","gd_send_pn_failure","gd_send_sms_failure","gd_send_voice_failure","gd_start_enroll_failed","gd_webauthn_challenge_failed","gd_webauthn_enrollment_failed","kms_key_management_failure","limit_delegation","limit_mu","limit_sul","limit_wc","my_account_authentication_method_failed","oidc_backchannel_logout_failed","passkey_challenge_failed","pwd_leak","reset_pwd_leak","rich_consents_access_error","signup_pwd_leak","ss_sso_failure","universal_logout_failed")){filterCategory = "Error";}
    if (has(eventCode) && (eventCode != "" || eventCode != "null" || eventCode != "nil") && in(eventCode, "acls_summary","kms_key_state_changed","mfar","pla","ss_sso_info")){filterCategory = "Info";}
    if (has(eventCode) && (eventCode != "" || eventCode != "null" || eventCode != "nil") && in(eventCode, "gd_tenant_update","appi","ciba_exchange_succeeded","ciba_start_succeeded","cls","cs","flows_execution_completed","forms_submission_succeeded","gd_auth_email_verification","gd_auth_succeed","gd_enrollment_complete","gd_recovery_succeed","gd_send_email","gd_send_email_verification","gd_send_pn","gd_send_sms","gd_send_voice","gd_start_auth","gd_start_enroll","gd_unenroll","gd_update_device_account","kms_key_management_success","mgmt_api_read","my_account_authentication_method_succeeded","oidc_backchannel_logout_succeeded","organization_member_added","passkey_challenge_started","resource_cleanup","s","sapi","sce","scoa","scp","scpn","scpr","scu","scv","sd","sdu","seacft","seccft","secte","sede","sens","seoobft","seotpft","sepft","sepkoobft","sepkotpft","sepkrcft","sercft","sertft","si","slo","srrt","ss","ss_sso_success","ssa","sscim","sui","sv","svr","ublkdu","universal_logout_succeeded")){filterCategory = "Success";}
    if (has(eventCode) && (eventCode != "" || eventCode != "null" || eventCode != "nil") && in(eventCode, "api_limit_warning","depnote","gd_otp_rate_limit_exceed","gd_recovery_rate_limit_exceed","too_many_records","w","wn","wum")){filterCategory = "Warning";}