// AlertQuery - Auth0 - Lifecycle - System API - Update Breached Password Detection Settings
tag=auth0 json
    date 
    type == "sapi" as eventType 
    description
    ip
    details.response.body.enabled == "false" as responseEnabled 
| lower description
| eval 
    description == "update breached password detection settings";
    _alert_name = "Breached Password Detection Settings Set to False";
| table