// AlertQuery - Auth0 - Lifecycle - System API - Modification to Passwordless Policy
tag=auth0 json 
    date 
    type == "sapi" as eventType 
    description == "Create or update the anomaly detection captcha"
    ip
    details.response.body.passwordless_policy == "off" as responseBodyPasswordlessPolicy
    details.response.statusCode == "200" as responseStatusCode
| eval 
    _alert_name = "Modification to Passwordless Policy";
| table 