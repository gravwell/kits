// AlertQuery - Auth0 - Lifecycle - System API - Modification to Password Login Policy
tag=auth0 json 
    date 
    type == "sapi" as eventType 
    description == "Create or update the anomaly detection captcha"
    ip
    details.response.body.policy == "off" as responseBodyPolicy
    details.response.statusCode == "200" as responseStatusCode
| eval 
    _alert_name = "Modification to Password Login Policy";
| table 