tag=$AUDITD kv -q type as auditType a0 a1 name
| eval (((auditType == "PATH") && in(name, "/etc/login.defs", "/etc/pam.d/auth", "/etc/pam.d/common-account", "/etc/pam.d/common-auth", "/etc/pam.d/common-password", "etc/pam.d/system-auth", "/etc/security/pwquality.conf"))
|| ((auditType == "EXECVE") && a0=="passwd" && in(a1, "-S", "--status")))