tag=$AUDITD kv -q type as auditType name
| eval (auditType == "PATH" && in(name,
    "/sys/class/dmi/id/bios_version",
    "/sys/class/dmi/id/product_name",
    "/sys/class/dmi/id/chassis_vendor",
    "/proc/scsi/scsi",
    "/proc/ide/hd0/model",
    "/proc/version",
    "/etc/*version",
    "/etc/*release",
    "/etc/issue"
    )
)