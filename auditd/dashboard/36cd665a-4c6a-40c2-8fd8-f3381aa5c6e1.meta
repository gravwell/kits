					"extras": {
						"defaultValue": null
					}
				}
			},
			{
				"alias": "Search 2",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" cmd AUID\n| grep \"res=failed\"\n| count auditType by AUID\n| table cmd AUID",
				"color": null
			},
			{
				"alias": "Search 3",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" cmd AUID acct\n| hexlify -d cmd as decoded_cmd\n| regex \"res=(?\u003csudo_status\u003esuccess|failed)\"\n| stats count by sudo_status over 1h\n| chart count by sudo_status",
				"color": null
			},
			{
				"alias": "Search 4",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" AUID cmd\n| hexlify -d cmd as decoded_cmd\n| regex \"res=(?\u003csudo_status\u003esuccess|failed)\"\n| eval sudo_status == \"failed\"\n| count by sudo_status\n| numbercard (count \"Sudo Failures\")",
				"color": null
			},
			{
				"alias": "Search 5",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" AUID cmd\n| hexlify -d cmd as decoded_cmd\n| regex \"res=(?\u003csudo_status\u003esuccess|failed)\"\n| eval sudo_status == \"failed\"\n| count by sudo_status\n| numbercard (count \"Sudo: \")",
				"color": null
			},
			{
				"alias": "Search 6",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" AUID cmd\n| hexlify -d cmd as decoded_cmd\n| regex \"res=(?\u003csudo_status\u003esuccess|failed)\"\n| count by AUID\n| chart count by AUID",
				"color": null
			},
			{
				"alias": "Search 7",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" AUID cmd\n| hexlify -d cmd as decoded_cmd\n| regex \"res=(?\u003csudo_status\u003esuccess|failed)\"\n| eval sudo_status == \"failed\"\n| table AUID decoded_cmd",
				"color": null
			},
			{
				"alias": "Search 8",
				"query": "tag=$AUDITD kv -q type as auditType exe == \"/usr/bin/sudo\" AUID cmd \n| hexlify -d cmd as decoded_cmd \n| regex \"res=(?\u003csudo_status\u003efailed)\" \n| eval failure = printf(\"Failed sudo attempts for User: %s\", AUID)\n| count by failure\n| numbercard (count \"\")",
				"color": null
			}
		],
