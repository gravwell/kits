{
	"UUID": "9942ce95-a16d-4c8b-a950-c44788a2060a",
	"Name": "Auditd - Identity Accountability",
	"Description": "Answer \"what did this account actually do\" across privilege contexts.",
	"Data": {
		"timeframe": {
			"durationString": null,
			"timeframe": "PT1H",
			"timezone": null,
			"start": null,
			"end": null
		},
		"searches": [
			{
				"alias": "Search 1",
				"query": "tag=$AUDITD kv -q type as auditType AUID\n| count auditType by AUID\n| table AUID count",
				"color": null
			},
			{
				"alias": "Search 2",
				"query": "tag=$AUDITD kv -q type as auditType AUID\n| count auditType by AUID\n| chart count by AUID",
				"color": null
			},
			{
				"alias": "Search 3",
				"query": "tag=$AUDITD kv -q -s type as auditType AUID EUID ses\n| eval (AUID != EUID) \u0026\u0026 (AUID != \"unset\")\n| stats unique_count(ses) as sessions by AUID EUID\n| eval transition = printf(\"(User: %s) → (User: %s)\", AUID, EUID)\n| count by transition\n| numbercard (count \"\")",
				"color": null
			}
		],
		"tiles": [
