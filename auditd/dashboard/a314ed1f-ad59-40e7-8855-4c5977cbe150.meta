{
	"UUID": "a314ed1f-ad59-40e7-8855-4c5977cbe150",
	"Name": "Auditd - Failed Operations",
	"Description": "Looks for unsuccessful syscalls events. Shows denied access, blocked operations, permissions issues.",
	"Data": {
		"timeframe": {
			"durationString": null,
			"timeframe": "P7DT",
			"timezone": null,
			"start": null,
			"end": null
		},
		"searches": [
			{
				"alias": "Search 1",
				"query": "tag=$AUDITD kv -q -s type == \"SYSCALL\" as auditType success == \"no\"\n| count\n| chart",
				"color": null
			},
			{
				"alias": "Search 2",
				"query": "tag=$AUDITD kv -q -s type == \"SYSCALL\" as auditType success == \"no\" AUID\n| stats count by AUID\n// | sort by count desc\n| chart count by AUID",
				"color": null
			},
			{
				"alias": "Search 3",
				"query": "tag=$AUDITD kv -q -s type == \"SYSCALL\" as auditType success == \"no\" exe\n| stats count by exe\n| sort by count desc\n| table exe count",
				"color": null
			},
			{
				"alias": "Search 4",
				"query": "tag=$AUDITD kv -q -s type == \"SYSCALL\" as auditType success == \"no\" SYSCALL\n| stats count by SYSCALL\n| sort by count desc\n| table SYSCALL count",
				"color": null
			}
		],
