{"id":"gravwell@0.0.1","nodes":{"3216":{"id":3216,"name":"HTTP","inputs":{"in":{"connections":[{"node":3225,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3219,"input":"in","data":{}}]}},"data":{"url":{"type":"Constant","value":"https://identity.bitwarden.com/connect/token"},"method":{"type":"Constant","value":"POST"},"body":{"type":"Variable","value":"BW_SECRET"},"maxsize":{"type":"Constant","value":67108864},"skipverify":{"type":"Constant","value":false},"headers":{"type":"Map","map":{"Content-Type":{"type":"Constant","value":"application/x-www-form-urlencoded"}}},"decodebody":{"type":"Constant","value":false},"__meta":{"nickname":"Bitwarden Auth","notes":null,"inputs":[],"values":{"url":{"type":{"kind":"string"},"value":"https://identity.bitwarden.com/connect/token"},"method":{"type":{"kind":"enum:string","values":["GET","POST","PUT","DELETE"]},"value":"POST"},"body":{"type":{"kind":"variable"},"value":"BW_SECRET"},"timeout":{"type":{"kind":"int"},"value":null},"maxsize":{"type":{"default":67108864,"kind":"int"},"value":67108864},"skipverify":{"type":{"kind":"boolean"},"value":false},"headers":{"Content-Type":{"type":{"kind":"string"},"value":"application/x-www-form-urlencoded"}},"decodebody":{"type":{"kind":"boolean"},"value":false}}},"__disabled":{"type":"Constant","value":false}},"position":[-1024,-480]},"3219":{"id":3219,"name":"Template","inputs":{"in":{"connections":[{"node":3216,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3265,"input":"in","data":{}}]}},"data":{"template":{"type":"Constant","value":"{{.response.access_token}}"},"name":{"type":"Constant","value":"token"},"__meta":{"nickname":"Set token variable","notes":null,"inputs":[],"values":{"template":{"type":{"kind":"string:longtext"},"value":"{{.response.access_token}}"},"name":{"type":{"default":"templateOutput","kind":"string"},"value":"token"}}},"__disabled":{"type":"Constant","value":false}},"position":[-784,-480]},"3224":{"id":3224,"name":"Ingest","inputs":{"in":{"connections":[{"node":3265,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[]}},"data":{"tag":{"type":"Variable","value":"BW_TAG"},"input":{"type":"Variable","value":"data"},"splitlines":{"type":"Constant","value":true},"extracttimestamp":{"type":"Constant","value":true},"__meta":{"nickname":null,"notes":null,"inputs":[],"values":{"tag":{"type":{"kind":"variable"},"value":"BW_TAG"},"input":{"type":{"kind":"variable"},"value":"data"},"splitlines":{"type":{"kind":"boolean"},"value":true},"extracttimestamp":{"type":{"kind":"boolean"},"value":true}}},"__disabled":{"type":"Constant","value":false}},"position":[-288,-480]},"3225":{"id":3225,"name":"Go","inputs":{"in":{"connections":[]}},"outputs":{"out":{"connections":[{"node":3216,"input":"in","data":{}}]}},"data":{"outputs":{"type":"Array","array_elements":[{"type":"Constant","value":"BW_SECRET"},{"type":"Constant","value":"BW_TAG"}]},"code":{"type":"Constant","value":"package main\n\nimport (\n\t\"gravwell\"\n)\n\nvar payload = gravwell.Payload\n\nfunc main() {\n    sec,err := gravwell.GetSecret(\"BW_SECRET\")\n    if err != nil {\n        panic(err)\n    }\n\n    tag,err := gravwell.GetMacro(\"$BITWARDEN_TAG\")\n    if err != nil {\n        panic(err)\n    } \n\n    payload.Set(\"BW_SECRET\",sec)\n    payload.Set(\"BW_TAG\",tag)\n    \n\treturn\n}"},"__meta":{"nickname":"Pull Bitwarden config macros","notes":null,"inputs":[],"values":{"outputs":[{"type":{"kind":"string"},"value":"BW_SECRET"},{"type":{"kind":"string"},"value":"BW_TAG"}],"code":{"type":{"default":"package main\n\nimport (\n\t\"gravwell\"\n)\n\n/* payload implements a Get and Set, like this interface: \ntype payload interface {\n\tGet(string) (interface{}, error)\n\tSet(string, interface{}) error\n}\n*/\n\nvar payload = gravwell.Payload\n\nfunc main() {\n\treturn\n}","kind":"string:code-go"},"value":"package main\n\nimport (\n\t\"gravwell\"\n)\n\nvar payload = gravwell.Payload\n\nfunc main() {\n    sec,err := gravwell.GetSecret(\"BW_SECRET\")\n    if err != nil {\n        panic(err)\n    }\n\n    tag,err := gravwell.GetMacro(\"$BITWARDEN_TAG\")\n    if err != nil {\n        panic(err)\n    } \n\n    payload.Set(\"BW_SECRET\",sec)\n    payload.Set(\"BW_TAG\",tag)\n    \n\treturn\n}"}}},"__disabled":{"type":"Constant","value":false}},"position":[-1344,-480]},"3265":{"id":3265,"name":"Go","inputs":{"in":{"connections":[{"node":3219,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3224,"input":"in","data":{}}]}},"data":{"outputs":{"type":"Array","array_elements":[{"type":"Constant","value":"data"}]},"code":{"type":"Constant","value":"package main\n\nimport (\n    \"gravwell\"\n    \"encoding/json\"\n    \"net/http\"\n    \"net/url\"\n    \"io\"\n    \"time\"\n    \"fmt\"\n)\n\ntype Response struct {\n    ContinuationToken string `json:\"continuationToken\"`\n    Data              []json.RawMessage //`json:\"data\"`\n    Object string `json:\"object\"`\n}\n\nvar payload = gravwell.Payload\n\nfunc main() {\n    // Grabbing all records from the last run until now\n    // using these should allow backfill of missed runs without double ingesting\n    start := gravwell.START.Add(time.Minute * time.Duration(-11))\n    end := gravwell.START.Add(time.Minute * time.Duration(-5))\n\n    params := url.Values{}\n    params.Set(\"start\", start.Format(time.RFC3339))\n    params.Set(\"end\", end.Format(time.RFC3339))\n\n    var continuation string\n    var data string\n    var endpoint string\n\n    // Set API endpoint\n    web,err := gravwell.GetMacro(\"$BITWARDEN_WEB\")\n    if err != nil {\n        panic(err)\n    }       \n\n    if web == \"api.bitwarden.com\" {\n        endpoint = web\n    } else {\n        endpoint = web + \"/api\"\n    }\n\n    for { // we loop forever until broken out but the `break` below\n        if continuation != \"\" {\n            params.Set(\"continuationToken\", continuation)\n        }\n\n        request, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/events?\"+params.Encode(), nil)\n        if err != nil {\n            panic(err)\n        }\n\n        // Read in the token that was passed in\n        t, err := payload.Get(\"token\")\n        if err != nil {\n            panic(err)\n        }\n\n        token, ok := t.(string)\n        if !ok {\n            panic(\"token not a string\")\n        }\n        \n        request.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\n        r, err := http.DefaultClient.Do(request)\n        if err != nil {\n            panic(err)\n        }\n\n        response, err := parse(r)\n        if err != nil {\n            panic(err)\n        }\n\n        for _, record := range response.Data {\n            data += string(record) + \"\\n\"\n        }\n\n        continuation = response.ContinuationToken\n        if response.ContinuationToken == \"\" {\n            break // this will break out as soon as there isn't any more records in the time range we are looking at\n        }\n    }\n    payload.Set(\"data\", data)\n    //println(string(data))\n    return\n}\n\n// parse out the body into a response\n// This closes the body\nfunc parse(response *http.Response) (*Response, error) {\n    body, err := io.ReadAll(response.Body)\n    response.Body.Close()\n    if err != nil {\n        return nil, err\n    }\n\n    var r Response\n    if err := json.Unmarshal(body, &r); err != nil {\n        return nil, err\n    }\n\n    return &r, nil\n}"},"__meta":{"nickname":"Pull event logs","notes":null,"inputs":[],"values":{"outputs":[{"type":{"kind":"string"},"value":"data"}],"code":{"type":{"default":"package main\n\nimport (\n\t\"gravwell\"\n)\n\n/* payload implements a Get and Set, like this interface: \ntype payload interface {\n\tGet(string) (interface{}, error)\n\tSet(string, interface{}) error\n}\n*/\n\nvar payload = gravwell.Payload\n\nfunc main() {\n\treturn\n}","kind":"string:code-go"},"value":"package main\n\nimport (\n    \"gravwell\"\n    \"encoding/json\"\n    \"net/http\"\n    \"net/url\"\n    \"io\"\n    \"time\"\n    \"fmt\"\n)\n\ntype Response struct {\n    ContinuationToken string `json:\"continuationToken\"`\n    Data              []json.RawMessage //`json:\"data\"`\n    Object string `json:\"object\"`\n}\n\nvar payload = gravwell.Payload\n\nfunc main() {\n    // Grabbing all records from the last run until now\n    // using these should allow backfill of missed runs without double ingesting\n    start := gravwell.START.Add(time.Minute * time.Duration(-11))\n    end := gravwell.START.Add(time.Minute * time.Duration(-5))\n\n    params := url.Values{}\n    params.Set(\"start\", start.Format(time.RFC3339))\n    params.Set(\"end\", end.Format(time.RFC3339))\n\n    var continuation string\n    var data string\n    var endpoint string\n\n    // Set API endpoint\n    web,err := gravwell.GetMacro(\"$BITWARDEN_WEB\")\n    if err != nil {\n        panic(err)\n    }       \n\n    if web == \"api.bitwarden.com\" {\n        endpoint = web\n    } else {\n        endpoint = web + \"/api\"\n    }\n\n    for { // we loop forever until broken out but the `break` below\n        if continuation != \"\" {\n            params.Set(\"continuationToken\", continuation)\n        }\n\n        request, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/events?\"+params.Encode(), nil)\n        if err != nil {\n            panic(err)\n        }\n\n        // Read in the token that was passed in\n        t, err := payload.Get(\"token\")\n        if err != nil {\n            panic(err)\n        }\n\n        token, ok := t.(string)\n        if !ok {\n            panic(\"token not a string\")\n        }\n        \n        request.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\n        r, err := http.DefaultClient.Do(request)\n        if err != nil {\n            panic(err)\n        }\n\n        response, err := parse(r)\n        if err != nil {\n            panic(err)\n        }\n\n        for _, record := range response.Data {\n            data += string(record) + \"\\n\"\n        }\n\n        continuation = response.ContinuationToken\n        if response.ContinuationToken == \"\" {\n            break // this will break out as soon as there isn't any more records in the time range we are looking at\n        }\n    }\n    payload.Set(\"data\", data)\n    //println(string(data))\n    return\n}\n\n// parse out the body into a response\n// This closes the body\nfunc parse(response *http.Response) (*Response, error) {\n    body, err := io.ReadAll(response.Body)\n    response.Body.Close()\n    if err != nil {\n        return nil, err\n    }\n\n    var r Response\n    if err := json.Unmarshal(body, &r); err != nil {\n        return nil, err\n    }\n\n    return &r, nil\n}"}}},"__disabled":{"type":"Constant","value":false}},"position":[-528,-480]}}}