n\r\n    var endpoint string\r\n    var data string\r\n\r\n\t// Set API endpoint\r\n    web, err := payload.Get(\"BITWARDEN_WEB\")\r\n    if err != nil {\r\n        panic(err)\r\n    }       \r\n\r\n    if web == \"api.bitwarden.com\" {\r\n        endpoint = web.(string)\r\n    } else {\r\n        endpoint = web.(string) + \"/api\"\r\n    }\r\n\r\n\trequest, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/members\", nil)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\t// Read in the token that was passed in\r\n\tt, err := payload.Get(\"token\")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\ttoken, ok := t.(string)\r\n\tif !ok {\r\n\t\tpanic(\"token not a string\")\r\n\t}\r\n\t\r\n\trequest.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\r\n\tr, err := http.DefaultClient.Do(request)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\t\r\n\tresponse, err := parse(r)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\t\r\n\tfor _, record := range response.Data {\r\n\t\tdata += string(record) + \"\\n\"\r\n\t}\r\n\r\npayload.Set(\"data\", data)\r\n//println(string(data))\r\nreturn\r\n\r\n}\r\n\r\n// parse out the body into a response\r\n// This closes the body\r\nfunc parse(response *http.Response) (*Response, error) {\r\n    body, err := io.ReadAll(response.Body)\r\n    response.Body.Close()\r\n    if err != nil {\r\n        return nil, err\r\n    }\r\n    \r\n    var r Response\r\n    if err := json.Unmarshal(body, &r); err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    return &r, nil\r\n}"},"__meta":{"nickname":"Pull member data","notes":null,"inputs":[],"values":{"outputs":[{"type":{"kind":"string"},"value":"data"}],"code":{"type":{"default":"package main\n\nimport (\n\t\"gravwell\"\n)\n\n/* payload implements a Get and Set, like this interface: \ntype payload interface {\n\tGet(string) (interface{}, error)\n\tSet(string, interface{}) error\n}\n*/\n\nvar payload = gravwell.Payload\n\nfunc main() {\n\treturn\n}","kind":"string:code-go"},"value":"package main\r\n\r\nimport (\r\n    \"gravwell\"\r\n    \"encoding/json\"\r\n    \"net/http\"\r\n    \"io\"\r\n    \"fmt\"\r\n)\r\n\r\ntype Response struct {\r\n\tObject string `json:\"object\"`\r\n\tData   []json.RawMessage `json:\"data\"`\r\n}\r\n\r\nvar payload = gravwell.Payload\r\n\r\nfunc main() {\r\n\r\n    var endpoint string\r\n    var data string\r\n\r\n\t// Set API endpoint\r\n    web, err := payload.Get(\"BITWARDEN_WEB\")\r\n    if err != nil {\r\n        panic(err)\r\n    }       \r\n\r\n    if web == \"api.bitwarden.com\" {\r\n        endpoint = web.(string)\r\n    } else {\r\n        endpoint = web.(string) + \"/api\"\r\n    }\r\n\r\n\trequest, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/members\", nil)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\t// Read in the token that was passed in\r\n\tt, err := payload.Get(\"token\")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\ttoken, ok := t.(string)\r\n\tif !ok {\r\n\t\tpanic(\"token not a string\")\r\n\t}\r\n\t\r\n\trequest.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\r\n\tr, err := http.DefaultClient.Do(request)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\t\r\n\tresponse, err := parse(r)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\t\r\n\tfor _, record := range response.Data {\r\n\t\tdata += string(record) + \"\\n\"\r\n\t}\r\n\r\npayload.Set(\"data\", data)\r\n//println(string(data))\r\nreturn\r\n\r\n}\r\n\r\n// parse out the body into a response\r\n// This closes the body\r\nfunc parse(response *http.Response) (*Response, error) {\r\n    body, err := io.ReadAll(response.Body)\r\n    response.Body.Close()\r\n    if err != nil {\r\n        return nil, err\r\n    }\r\n    \r\n    var r Response\r\n    if err := json.Unmarshal(body, &r); err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    return &r, nil\r\n}"}}},"__disabled":{"type":"Constant","value":false}},"position":[-512,-4