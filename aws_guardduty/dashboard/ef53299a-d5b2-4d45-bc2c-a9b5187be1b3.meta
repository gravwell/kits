	"Name": "AWS GuardDuty - Findings by Severity",
	"Description": "",
	"Data": {
		"timeframe": {
			"durationString": null,
			"timeframe": "P30DT",
			"timezone": null,
			"start": null,
			"end": null
		},
		"searches": [
			{
				"alias": "Search 1",
				"query": "tag=aws-guardduty $GUARDDUTY_RATING\n| count by severity_rating\n| numbercard (count \"Severity: \")",
				"color": null
			},
			{
				"alias": "Search 2",
				"query": "tag=aws-guardduty json accountId type title description severity as severity_value\n| eval severity_value \u003e= 9\n$GUARDDUTY_ALERT(\"Critical\")",
				"color": null
			},
			{
				"alias": "Search 3",
				"query": "tag=aws-guardduty json accountId type title description severity as severity_value\n| eval severity_value \u003e= 7 \u0026\u0026 severity_value \u003c= 8.9\n$GUARDDUTY_ALERT(\"High\")",
				"color": null
			},
			{
				"alias": "Search 4",
				"query": "tag=aws-guardduty json accountId type title description severity as severity_value | eval severity_value \u003e= 7 \u0026\u0026 severity_value \u003c= 8.9 $GUARDDUTY_ALERT(\"Medium\")",
				"color": null
			},
			{
				"alias": "Search 5",
				"query": "tag=aws-guardduty json accountId type title description severity as severity_value | eval severity_value \u003e= 7 \u0026\u0026 severity_value \u003c= 8.9 $GUARDDUTY_ALERT(\"Low\")",
				"color": null
			},
