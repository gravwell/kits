{
	"UUID": "2592df6e-5910-4319-93d9-098f9541d861",
	"Name": "Template - Fortinet - Investigation - Events - Types \u0026 Subtypes for IP [numbercard]",
	"Description": "This template returns a numbercard of types \u0026 subtypes for all events found within the Fortinet Event logs for IP in either the srcip or the dstip Enumerated Values (EVs).",
	"Data": {
		"variables": [
			{
				"name": "%%time%%",
				"label": "Time",
				"description": "s: sec; m:min; h:hr; d:day; y:year",
				"required": true,
				"defaultValue": "24h",
				"previewValue": "24h"
			},
			{
				"name": "%%ip%%",
				"label": "IP Address",
				"description": "This is either the srcip or the dstip from which the action was performed.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"fortinet"
	]
}