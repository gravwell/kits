{
	"UUID": "c702d535-048d-4d0d-a137-6932a95b5614",
	"Name": "Template - Fortinet - Investigation - UTM - All Events for IP [table]",
	"Description": "This template returns all Traffic events found within the Fortinet UTM logs for IP in either the srcip or the dstip Enumerated Values (EVs).",
	"Data": {
		"variables": [
			{
				"name": "%%time%%",
				"label": "Time",
				"description": "s: sec; m:min; h:hr; d:day; y:year",
				"required": true,
				"defaultValue": "24h",
				"previewValue": "24h"
			},
			{
				"name": "%%ip%%",
				"label": "IP Address",
				"description": "This is either the srcip or the dstip from which the action was performed.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"fortinet"
	]
}