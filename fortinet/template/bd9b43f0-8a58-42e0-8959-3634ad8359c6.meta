{
	"UUID": "bd9b43f0-8a58-42e0-8959-3634ad8359c6",
	"Name": "Template - Fortinet - Events - EV - Count [table]",
	"Description": "Displays a table of the specified Fortinet Events grouped by the specified Enumerated Values (EVs). Used on the Fortinet Events Overview dashboard.\n\nFortinet EV 0 must be populated with a variable.\nFortinet EV 1 \u0026 Fortinet EV 2 may be left empty.",
	"Data": {
		"variables": [
			{
				"name": "%%ev0%%",
				"label": "Fortinet EV 0",
				"description": "Any extracted Traffic EV; Top Options: subtype,level,srcip,srcport,dstip,dstport,authproto,action,policyid,alert,status,profile",
				"required": true,
				"defaultValue": "subtype",
				"previewValue": "subtype"
			},
			{
				"name": "%%ev1%%",
				"label": "Fortinet EV 1",
				"description": "Any extracted Traffic EV; Top Options: subtype,level,srcip,srcport,dstip,dstport,authproto,action,policyid,alert,status,profile",
				"required": true,
				"defaultValue": "ev1",
				"previewValue": "ev1"
			},
			{
				"name": "%%ev2%%",
				"label": "Fortinet EV 2",
				"description": "Any extracted Traffic EV; Top Options: subtype,level,srcip,srcport,dstip,dstport,authproto,action,policyid,alert,status,profile",
				"required": true,
				"defaultValue": "ev2",
				"previewValue": "ev2"
			}
		]
	},
	"Labels": [
		"fortinet"
	]
}