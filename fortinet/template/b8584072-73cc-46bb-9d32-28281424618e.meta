{
	"UUID": "b8584072-73cc-46bb-9d32-28281424618e",
	"Name": "Template - Fortinet - Investigation - Event Types - Count by Tag [numbercard]",
	"Description": "This template returns a numbercard of all events found within any of the Fortinet Logs for IP in either the srcip or the dstip Enumerated Values (EVs).",
	"Data": {
		"variables": [
			{
				"name": "%%time%%",
				"label": "Time",
				"description": "s: sec; m:min; h:hr; d:day; y:year",
				"required": true,
				"defaultValue": "24h",
				"previewValue": "24h"
			},
			{
				"name": "%%ip%%",
				"label": "IP Address",
				"description": "This is either the srcip or the dstip from which the action was performed.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"fortinet"
	]
}