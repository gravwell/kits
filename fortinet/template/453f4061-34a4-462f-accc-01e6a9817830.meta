{
	"UUID": "453f4061-34a4-462f-accc-01e6a9817830",
	"Name": "Template - Fortinet - Investigation - Event Types - Count by Tag [chart]",
	"Description": "This template returns a chart of all events found within any of the Fortinet Logs for IP in either the srcip or the dstip Enumerated Values (EVs).",
	"Data": {
		"variables": [
			{
				"name": "%%time%%",
				"label": "Time",
				"description": "s: sec; m:min; h:hr; d:day; y:year",
				"required": true,
				"defaultValue": "24h",
				"previewValue": "24h"
			},
			{
				"name": "%%ip%%",
				"label": "IP Address",
				"description": "This is either the srcip or the dstip from which the action was performed.",
				"required": true,
				"defaultValue": ".",
				"previewValue": "."
			}
		]
	},
	"Labels": [
		"fortinet"
	]
}