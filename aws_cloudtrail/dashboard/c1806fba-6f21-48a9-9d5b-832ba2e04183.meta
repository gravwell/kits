					"XAxisSplitLine": "no",
					"YAxisSplitLine": "no",
					"IncludeOther": "yes",
					"ConnectNulls": "yes",
					"LogScale": "no"
				}
			},
			{
				"id": 5867535586192917,
				"title": "Top Error Generators",
