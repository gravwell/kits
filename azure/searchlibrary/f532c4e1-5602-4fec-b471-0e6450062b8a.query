tag=$AZURE_ACTIVITY json operationName callerIpAddress resourceId resultType
| eval (
    operationName == "MICROSOFT.AUTHORIZATION/ROLEASSIGNMENTS/WRITE" ||
    operationName == "MICROSOFT.AUTHORIZATION/ROLEASSIGNMENTS/DELETE" ||
    operationName == "MICROSOFT.AUTHORIZATION/ELEVATEACCESS/ACTION" ||
    operationName == "MICROSOFT.AUTHORIZATION/POLICYASSIGNMENTS/WRITE" ||
    operationName == "MICROSOFT.AUTHORIZATION/POLICYASSIGNMENTS/DELETE" ||
    operationName == "MICROSOFT.AUTHORIZATION/LOCKS/WRITE" ||
    operationName == "MICROSOFT.AUTHORIZATION/LOCKS/DELETE" ||
    operationName == "MICROSOFT.COMPUTE/SNAPSHOTS/WRITE" ||
    operationName == "MICROSOFT.STORAGE/STORAGEACCOUNTS/LISTKEYS/ACTION" ||
    operationName == "MICROSOFT.DOCUMENTDB/DATABASEACCOUNTS/LISTKEYS/ACTION" ||
    operationName == "MICROSOFT.KEYVAULT/VAULTS/WRITE" ||
    operationName == "MICROSOFT.KEYVAULT/VAULTS/DELETE" ||
    operationName == "MICROSOFT.KEYVAULT/VAULTS/ACCESSPOLICIES/WRITE" ||
    operationName == "MICROSOFT.SECURITY/ALERTSSUPPRESSIONRULES/WRITE"
  )
| table