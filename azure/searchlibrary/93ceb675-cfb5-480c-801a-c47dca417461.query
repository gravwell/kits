tag=$AZURE_ACTIVITY json operationName callerIpAddress resourceId resultType correlationId
| eval (
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/WRITE" ||
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/DELETE" ||
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/RESET/ACTION" ||
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/GENERATEVPNPROFILE/ACTION" ||
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/DISCONNECTP2SVPNCONNECTIONS/ACTION" ||
    operationName == "MICROSOFT.NETWORK/P2SVPNGATEWAYS/PROVIDERS/MICROSOFT.INSIGHTS/DIAGNOSTICSETTINGS/WRITE"
  )
| table